<Window x:Class="CtrlTranslator.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440"
        Height="160"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        ResizeMode="NoResize">

    <!-- Outer padding provides clearance for drop shadow -->
    <Border Padding="12">

        <!-- Card with drop shadow and left accent border -->
        <Border CornerRadius="12"
                Background="#ED1A1A2E"
                BorderBrush="#5B6EF5"
                BorderThickness="4,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.38"
                                  BlurRadius="14"
                                  ShadowDepth="3"
                                  Direction="270"/>
            </Border.Effect>

            <StackPanel Margin="14,12,16,12">
                <!-- Source / original text -->
                <TextBlock x:Name="SourceTextBlock"
                           Foreground="#80FFFFFF"
                           FontSize="12"
                           FontFamily="{StaticResource AppFontFamily}"
                           TextWrapping="Wrap"
                           MaxHeight="36"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Thin separator -->
                <Border Height="1"
                        Background="#1AFFFFFF"
                        Margin="0,8,0,0"/>

                <!-- Translated text -->
                <TextBlock x:Name="TranslatedTextBlock"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           FontFamily="{StaticResource AppFontFamily}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </Border>
</Window>
