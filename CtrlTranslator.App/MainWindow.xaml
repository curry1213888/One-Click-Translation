<Window x:Class="CtrlTranslator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ctrl Translator"
        Width="400"
        Height="600"
        Icon="app.ico"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        PreviewKeyUp="Window_OnPreviewKeyUp"
        PreviewMouseRightButtonDown="Window_OnPreviewMouseRightButtonDown"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="{StaticResource AppFontFamily}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="92"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- ══ Gradient Header ══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5B6EF5" Offset="0"/>
                    <GradientStop Color="#7C3AED" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="24,0">
                <!-- Left: icon + name + subtitle -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="12" Background="#33FFFFFF">
                        <TextBlock Text="C"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Ctrl Translator"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TriggerHotkeyHintText}"
                                   Foreground="#BBFFFFFF"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: live status indicator -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#10B981"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AutoTranslateEnabled}" Value="False">
                                        <Setter Property="Fill" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="运行中"/>
                                <Setter Property="Foreground" Value="#AAFFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AutoTranslateEnabled}" Value="False">
                                        <Setter Property="Text"       Value="已暂停"/>
                                        <Setter Property="Foreground" Value="#66FFFFFF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Settings Rows ══ -->
        <StackPanel Grid.Row="1">

            <!-- Auto Translate -->
            <Border Padding="24,20"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                        <TextBlock Text="自动翻译"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding TriggerHotkeyHintText}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <CheckBox Style="{StaticResource ToggleSwitch}"
                              IsChecked="{Binding AutoTranslateEnabled}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Trigger Hotkey -->
            <Border Padding="24,20"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="翻译快捷键"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding HotkeyStatusText}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <ComboBox Width="122"
                                  Style="{StaticResource AppComboBox}"
                                  ItemsSource="{Binding HotkeyOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedHotkeyOptionId}"/>
                        <Button Margin="8,0,0,0"
                                Width="98"
                                Height="32"
                                Command="{Binding StartHotkeyRecordingCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Setter Property="Content" Value="录制自定义"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecordingHotkey}" Value="True">
                                            <Setter Property="Content" Value="正在录制..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Translation Languages -->
            <Border Padding="24,20"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="翻译语种"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding LanguageDirection}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <ComboBox Style="{StaticResource LanguageComboBox}"
                                  ItemsSource="{Binding Languages}"
                                  SelectedValue="{Binding SourceLanguage}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="Name"/>
                        <Button Style="{StaticResource SwapButton}"
                                Content="⇄"
                                Margin="6,0"
                                Command="{Binding SwapLanguagesCommand}"/>
                        <ComboBox Style="{StaticResource LanguageComboBox}"
                                  ItemsSource="{Binding Languages}"
                                  SelectedValue="{Binding TargetLanguage}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="Name"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Start with Windows -->
            <Border Padding="24,20"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                        <TextBlock Text="开机启动"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="登录 Windows 时自动在后台启动"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <CheckBox Style="{StaticResource ToggleSwitch}"
                              IsChecked="{Binding StartWithWindows}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Close Behavior -->
            <Border Padding="24,20"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                        <TextBlock Text="关闭最小化到托盘"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CloseBehaviorDescription}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <CheckBox Style="{StaticResource ToggleSwitch}"
                              IsChecked="{Binding MinimizeToTrayOnClose}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Translation Service (read-only badge) -->
            <Border Padding="24,20">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="翻译服务"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="通过有道智云 API 进行翻译"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="{StaticResource AccentLightBrush}"
                            CornerRadius="20"
                            Padding="12,5">
                        <TextBlock Text="有道智云"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12"
                                   FontWeight="Medium"/>
                    </Border>
                </Grid>
            </Border>

        </StackPanel>

        <!-- ══ Footer ══ -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,0">
            <Grid>
                <TextBlock Text="{Binding CloseBehaviorDescription}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Content="配置 API 密钥"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{Binding OpenSettingsCommand}"/>
            </Grid>
        </Border>

    </Grid>
</Window>
